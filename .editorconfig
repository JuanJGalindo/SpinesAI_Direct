# EditorConfig — https://editorconfig.org
# Matches the conventions used across the SpinesAI / hamiltoniannet workspace.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,ipynb}]
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json}]
indent_size = 2
